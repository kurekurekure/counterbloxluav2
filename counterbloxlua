-- Load / refresh seraph9 every frame (cached fetch). Re-running it refreshes
-- input (key/mouse) which the menu's Render closure reads.
do
	local ui_url = config.urls.UI or config.urls.DXLibUI
		or "https://raw.githubusercontent.com/x8n8x/srp/refs/heads/main/seraph9.lua";
	local src = dx9.Get(ui_url);
	if type(src) == "string" and src ~= "" then
		local chunk = loadstring(src);
		if chunk then chunk(); end
	end
end

if type(library) ~= "table" or type(library.Window) ~= "function" then
	-- UI failed to load (bad fetch). Show console so the error is visible.
	dx9.ShowConsole(true);
	return;
end

local function notify(msg)
	if type(send_notif) == "function" then send_notif(msg); end
end

local function flag_on(name)
	return library.flags[name] == true;
end

local function flag_num(name, default)
	local v = library.flags[name];
	if type(v) == "number" then return v; end
	return default or 0;
end

local function flag_str(name, default)
	local v = library.flags[name];
	if type(v) == "string" then return v; end
	return default or "";
end

local function rgb(prefix)
	return {
		library.flags[prefix .. "_r"] or 0;
		library.flags[prefix .. "_g"] or 0;
		library.flags[prefix .. "_b"] or 0;
	};
end

-- Color sliders own their values via seraph flags (default applied once).
local function add_rgb(section, prefix, label, default)
	section:slider({ name = label .. " R", flag = prefix .. "_r", min = 0, max = 255, default = default[1], interval = 1 });
	section:slider({ name = label .. " G", flag = prefix .. "_g", min = 0, max = 255, default = default[2], interval = 1 });
	section:slider({ name = label .. " B", flag = prefix .. "_b", min = 0, max = 255, default = default[3], interval = 1 });
end

local function get_position(instance)
	local pos = dx9.GetPosition(instance);
	if type(pos) == "table" and pos.x ~= nil then return pos; end
	return nil;
end

local function world_to_screen_loose(x, y, z)
	local screen = dx9.WorldToScreen({ x, y, z });
	if type(screen) ~= "table" or screen.x == nil or screen.y == nil then return nil; end
	if screen.x < 0 or screen.y < 0 then return nil; end
	return screen;
end

local function get_cframe(part)
	local cf = dx9.GetCFrame(part);
	if type(cf) == "table" and cf.RightVector and cf.LookVector and cf.UpVector then return cf; end
	local _, right, look, up = dx9.GetCFrame(part);
	if type(right) == "table" and type(look) == "table" and type(up) == "table" then
		return { RightVector = right; LookVector = look; UpVector = up; };
	end
	return nil;
end

local function valid_pointer(ptr)
	return ptr ~= nil and ptr ~= 0 and ptr ~= false;
end

local function menu_open()
	return _G._sr and _G._sr.visible == true;
end

local function screen_center()
	local sw = dx9.size().width;
	local sh = dx9.size().height;
	return sw / 2, sh / 2;
end

local function get_planted_bomb()
	if not cache.workspace then return nil; end
	local c4 = dx9.FindFirstChild(cache.workspace, "C4");
	if valid_pointer(c4) and valid_pointer(dx9.FindFirstChild(c4, "Handle")) then
		return c4;
	end
	return nil;
end

local function fov_pixels()
	local fov_deg = flag_num("aimbot_fov", 90);
	return (fov_deg / 90) * (dx9.size().height * 0.42);
end

local function get_aim_screen(entry)
	local bone = flag_str("aim_bone", "Head");
	if entry.name and dx9.get_info then
		local info = dx9.get_info(entry.name, bone);
		if type(info) == "table" and type(info.Position) == "table" then
			local p = info.Position;
			local s = world_to_screen_loose(p.x, p.y, p.z);
			if s then return s; end
		end
	end
	if bone == "Head" and entry.head_pos then
		return world_to_screen_loose(entry.head_pos.x, entry.head_pos.y, entry.head_pos.z);
	end
	if entry.root_pos then
		return world_to_screen_loose(entry.root_pos.x, entry.root_pos.y + 1.2, entry.root_pos.z);
	end
	return nil;
end

local function dist3(a, b)
	local dx, dy, dz = a.x - b.x, a.y - b.y, a.z - b.z;
	return math.sqrt(dx * dx + dy * dy + dz * dz);
end

local function should_skip_player(player_inst, is_teammate)
	if player_inst == cache.local_player then return true; end
	if flag_on("teamcheck_enabled") and is_teammate then return true; end
	return false;
end

local function refresh_cache()
	cache.frame = cache.frame + 1;
	if cache.frame % 8 ~= 0 and cache.datamodel then return; end

	cache.datamodel = dx9.GetDatamodel();
	if not cache.datamodel then return; end

	local players_folder = dx9.FindFirstChild(cache.datamodel, "Players");
	cache.workspace = dx9.FindFirstChild(cache.datamodel, "Workspace");
	cache.players = players_folder and dx9.GetChildren(players_folder) or {};
	cache.debris = cache.workspace and dx9.FindFirstChild(cache.workspace, "Debris") or nil;
	cache.ray_ignore = cache.workspace and dx9.FindFirstChild(cache.workspace, "Ray_Ignore") or nil;

	cache.local_pos = nil;
	cache.local_team = nil;
	cache.local_player = nil;

	local local_info = dx9.get_localplayer();
	if local_info and local_info.Position then
		cache.local_pos = local_info.Position;
	end

	for _, p in next, cache.players do
		local char = dx9.GetCharacter(p);
		if char then
			local root = dx9.FindFirstChild(char, "HumanoidRootPart");
			if root then
				local pos = get_position(root);
				if pos and cache.local_pos and dist3(pos, cache.local_pos) < 2 then
					cache.local_team = dx9.GetTeam(p);
					cache.local_player = p;
					break;
				end
			end
		end
	end
end

local function get_player_entries()
	local entries = {};
	local max_dist = flag_num("player_max_dist", config.players.player_max_dist or 500);

	for _, player_inst in next, cache.players do
		local char = dx9.GetCharacter(player_inst);
		if char then
			local is_teammate = false;
			if cache.local_team then
				local pt = dx9.GetTeam(player_inst);
				if pt and pt == cache.local_team then is_teammate = true; end
			end
			if not should_skip_player(player_inst, is_teammate) then
				local head = dx9.FindFirstChild(char, "Head");
				local root = dx9.FindFirstChild(char, "HumanoidRootPart")
					or dx9.FindFirstChild(char, "Torso")
					or dx9.FindFirstChild(char, "UpperTorso");
				local humanoid = dx9.FindFirstChild(char, "Humanoid");
				if head and root then
					local head_pos = get_position(head);
					local root_pos = get_position(root);
					if head_pos and root_pos then
						local in_range = true;
						if cache.local_pos then
							in_range = dist3(root_pos, cache.local_pos) <= max_dist;
						end
						if in_range then
							entries[#entries + 1] = {
								player = player_inst;
								character = char;
								head = head;
								root = root;
								humanoid = humanoid;
								name = dx9.GetName(player_inst);
								is_teammate = is_teammate;
								head_pos = head_pos;
								root_pos = root_pos;
								distance = cache.local_pos and dist3(root_pos, cache.local_pos) or 0;
							};
						end
					end
				end
			end
		end
	end
	return entries;
end

