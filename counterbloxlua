local function normalize_bind_name(name)
	if type(name) ~= "string" or name == "" then return ""; end
	name = name:upper();
	local inner = name:match("^%[(.+)%]$");
	if inner then name = inner; end
	return name;
end

local function resolve_bind_name(name)
	name = normalize_bind_name(name);
	if name == "" then return ""; end
	return BIND_ALIASES[name] or name;
end

local function format_bind_key(key)
	key = resolve_bind_name(key);
	if key == "" then return "?"; end
	return KEY_DISPLAY[key] or key;
end

local function get_bind_key_name(flag, fallback)
	if _G._sr and _G._sr.items then
		for _, it in pairs(_G._sr.items) do
			if it.type == "keybind" and it.flag == flag and it.key and it.key ~= "NONE" then
				return resolve_bind_name(it.key);
			end
		end
	end
	local v = library.flags[flag];
	if type(v) == "string" and v ~= "" then
		return resolve_bind_name(v);
	end
	if S.keybind_names and S.keybind_names[flag] then
		return S.keybind_names[flag];
	end
	return resolve_bind_name(fallback);
end

local function key_down(code)
	if dx9.GetKey() == code then return true; end
	local keys = dx9.GetKeys();
	if type(keys) == "table" then
		for _, k in ipairs(keys) do
			if k == code then return true; end
		end
	end
	return false;
end

local function sync_keybind_name(flag, fallback)
	S.keybind_names = S.keybind_names or {};
	local name = get_bind_key_name(flag, fallback);
	S.keybind_names[flag] = name;
	S.keybind_labels[flag] = format_bind_key(name);
	return S.keybind_labels[flag];
end

local function keybind_held(flag, fallback)
	if library.flags[flag] == true then return true; end

	local name = get_bind_key_name(flag, fallback);
	local codes = KEY_HELD_CODES[name];
	if codes then
		for _, code in ipairs(codes) do
			if code == "[XBUTTON1]" or code == "[XBUTTON2]" then
				if key_down(code) then return true; end
			elseif dx9.GetKey() == code then
				return true;
			end
		end
	end

	if dx9.GetKey() == "[" .. name .. "]" then return true; end

	if name == "RBUTTON" or name == "M2" then return dx9.isRightClickHeld(); end
	if name == "LBUTTON" or name == "M1" then return dx9.isLeftClickHeld(); end
	if name == "MBUTTON" or name == "M3" then return dx9.GetKey() == "[MBUTTON]"; end
	if name == "XBUTTON1" or name == "MB4" or name == "M4" or name == "MOUSE4" then
		return key_down("[XBUTTON1]");
	end
	if name == "XBUTTON2" or name == "MB5" or name == "M5" or name == "MOUSE5" then
		return key_down("[XBUTTON2]");
	end

	return false;
end

local function on_keybind_set(flag, value)
	S.keybind_names = S.keybind_names or {};
	if type(value) == "string" and value ~= "" then
		S.keybind_names[flag] = resolve_bind_name(value);
		S.keybind_labels[flag] = format_bind_key(value);
	end
end

local function snapshot_flags()
	local copy = {};
	for k, v in pairs(library.flags) do
		if type(v) == "boolean" or type(v) == "number" or type(v) == "string" then
			copy[k] = v;
		end
	end
	return copy;
end

local function apply_flags(saved)
	for k, v in pairs(saved) do
		library.flags[k] = v;
	end
end

-- Color sliders own their values via seraph flags (default applied once).
local function add_rgb(section, prefix, label, default)
	section:slider({ name = label .. " R", flag = prefix .. "_r", min = 0, max = 255, default = default[1], interval = 1 });
	section:slider({ name = label .. " G", flag = prefix .. "_g", min = 0, max = 255, default = default[2], interval = 1 });
	section:slider({ name = label .. " B", flag = prefix .. "_b", min = 0, max = 255, default = default[3], interval = 1 });
end

local function get_position(instance)
	local pos = dx9.GetPosition(instance);
	if type(pos) == "table" and pos.x ~= nil then return pos; end
	return nil;
end

local function world_to_screen_loose(x, y, z)
	local screen = dx9.WorldToScreen({ x, y, z });
	if type(screen) ~= "table" or screen.x == nil or screen.y == nil then return nil; end
	if screen.x < 0 or screen.y < 0 then return nil; end
	return screen;
end

local function get_cframe(part)
	local cf = dx9.GetCFrame(part);
	if type(cf) == "table" and cf.RightVector and cf.LookVector and cf.UpVector then return cf; end
	local _, right, look, up = dx9.GetCFrame(part);
	if type(right) == "table" and type(look) == "table" and type(up) == "table" then
		return { RightVector = right; LookVector = look; UpVector = up; };
	end
	return nil;
end

local function valid_pointer(ptr)
	return ptr ~= nil and ptr ~= 0 and ptr ~= false;
end

