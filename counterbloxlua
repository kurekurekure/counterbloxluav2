local function run_smoke_radius()
	if not flag_on("esp_enabled") or not flag_on("smoke_radius_enabled") or not cache.smoke_list then return; end

	local color = rgb("smoke");
	for _, smoke in ipairs(cache.smoke_list) do
		local pos = get_position(smoke);
		if pos then
			local gy = pos.y - 0.5;
			local prev;
			for i = 0, 16 do
				local a = (2 * math.pi / 16) * i;
				local pt = world_to_screen_loose(pos.x + 10.5 * math.cos(a), gy, pos.z + 10.5 * math.sin(a));
				if pt and prev then dx9.DrawLine(prev, { pt.x, pt.y }, color); end
				if pt then prev = { pt.x, pt.y }; end
			end
		end
	end
end

local function run_molotov_radius()
	if not flag_on("esp_enabled") or not flag_on("mol_radius_enabled") or not cache.fire_list then return; end

	local color = rgb("mol");
	for _, fire in ipairs(cache.fire_list) do
		local pos = get_position(fire);
		if pos then
			local gy = pos.y - 0.5;
			local hs = 12;
			local c = {
				world_to_screen_loose(pos.x - hs, gy, pos.z - hs),
				world_to_screen_loose(pos.x + hs, gy, pos.z - hs),
				world_to_screen_loose(pos.x + hs, gy, pos.z + hs),
				world_to_screen_loose(pos.x - hs, gy, pos.z + hs),
			};
			if c[1] and c[2] and c[3] and c[4] then
				dx9.DrawLine({ c[1].x, c[1].y }, { c[2].x, c[2].y }, color);
				dx9.DrawLine({ c[2].x, c[2].y }, { c[3].x, c[3].y }, color);
				dx9.DrawLine({ c[3].x, c[3].y }, { c[4].x, c[4].y }, color);
				dx9.DrawLine({ c[4].x, c[4].y }, { c[1].x, c[1].y }, color);
			end
		end
	end
end

local function run_bomb_timer()
	if not flag_on("bomb_timer") then S.bomb.active = false; return; end

	local bt = S.bomb;
	local now = os.clock();
	local planted = cache.workspace and dx9.FindFirstChild(cache.workspace, "C4") or nil;
	local is_planted = false;
	if valid_pointer(planted) and valid_pointer(dx9.FindFirstChild(planted, "Handle")) then
		is_planted = true;
	end

	if is_planted and not bt.active then
		bt.active = true;
		bt.start = now;
		bt.ended_at = 0;
	end

	if not bt.active then return; end

	local remaining = 40.0 - (now - bt.start);

	-- Defused / removed before detonation.
	if not is_planted and remaining > 0 then
		bt.active = false;
		return;
	end

	local label, col;
	if remaining > 0 then
		label = string.format("BOMB  %.2f", remaining);
		if remaining <= 10 then col = { 255, 60, 60 };
		elseif remaining <= 20 then col = { 255, 170, 0 };
		else col = { 235, 235, 235 }; end
	else
		if bt.ended_at == 0 then bt.ended_at = now; end
		if now - bt.ended_at > 2.5 then bt.active = false; return; end
		label = "DETONATED";
		col = { 255, 40, 40 };
	end

	local tw = dx9.CalcTextWidth(label);
	local w = math.max(120, tw + 24);
	local h = 26;
	local x = dx9.size().width / 2 - w / 2;
	local y = 34;
	dx9.DrawFilledBox({ x, y }, { x + w, y + h }, { 18, 18, 18 });
	dx9.DrawBox({ x, y }, { x + w, y + h }, { 60, 60, 60 });
	dx9.DrawFilledBox({ x, y }, { x + w, y + 2 }, col);
	dx9.DrawString({ x + (w - tw) / 2, y + 8 }, col, label);
end

local function draw_color_picker()
	local p = S.picker;
	if not p then return; end

	local mouse = dx9.GetMouse();
	local mx, my = mouse.x, mouse.y;
	local held = dx9.isLeftClickHeld();
	local click = held and not S.picker_lmb_prev;

	local w, h = 200, 132;
	local x = dx9.size().width - w - 24;
	local y = dx9.size().height / 2 - h / 2;

	dx9.DrawFilledBox({ x, y }, { x + w, y + h }, { 20, 20, 20 });
	dx9.DrawBox({ x, y }, { x + w, y + h }, { 60, 60, 60 });
	dx9.DrawFilledBox({ x, y }, { x + w, y + 18 }, { 32, 32, 32 });
	dx9.DrawString({ x + 6, y + 4 }, { 230, 230, 230 }, p.label);

	-- close button
	local close_x = x + w - 14;
	dx9.DrawString({ close_x, y + 4 }, { 230, 120, 120 }, "x");
	if click and mx >= close_x - 4 and mx <= x + w and my >= y and my <= y + 18 then
		S.picker = nil;
		S.picker_lmb_prev = held;
		return;
	end

	local chans = { "r", "g", "b" };
	local labels = { "R", "G", "B" };
	local chan_cols = { { 255, 80, 80 }, { 80, 255, 80 }, { 90, 150, 255 } };
	for i = 1, 3 do
		local by = y + 28 + (i - 1) * 26;
		local bx = x + 22;
		local bw = w - 74;
		local bh = 10;
		local fname = p.prefix .. "_" .. chans[i];
		local val = library.flags[fname] or 0;

		dx9.DrawString({ x + 6, by - 1 }, { 200, 200, 200 }, labels[i]);
		dx9.DrawFilledBox({ bx, by }, { bx + bw, by + bh }, { 45, 45, 45 });
		local fw = math.floor(bw * (val / 255));
		if fw > 0 then dx9.DrawFilledBox({ bx, by }, { bx + fw, by + bh }, chan_cols[i]); end
		dx9.DrawBox({ bx, by }, { bx + bw, by + bh }, { 75, 75, 75 });
		dx9.DrawString({ bx + bw + 8, by - 1 }, { 185, 185, 185 }, tostring(math.floor(val)));

		if held and mx >= bx and mx <= bx + bw and my >= by - 6 and my <= by + bh + 6 then
			local nv = math.floor((mx - bx) / bw * 255 + 0.5);
			if nv < 0 then nv = 0; elseif nv > 255 then nv = 255; end
			library.flags[fname] = nv;
		end
	end

	-- preview swatch
	local pv = {
		library.flags[p.prefix .. "_r"] or 0,
		library.flags[p.prefix .. "_g"] or 0,
		library.flags[p.prefix .. "_b"] or 0,
	};
	dx9.DrawFilledBox({ x + 6, y + h - 16 }, { x + w - 6, y + h - 6 }, pv);
	dx9.DrawBox({ x + 6, y + h - 16 }, { x + w - 6, y + h - 6 }, { 75, 75, 75 });

	S.picker_lmb_prev = held;
end

