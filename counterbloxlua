if _G.transitionTime == nil then _G.transitionTime = 0; end
if _G.colorIndex == nil then _G.colorIndex = 1; end
if _G.frameCounter == nil then _G.frameCounter = 0; end

local function lerp(a, b, t)
	return a + (b - a) * t;
end

local function getSmoothRainbowColor()
	local totalColors = #rainbowColors;
	local startColor = rainbowColors[_G.colorIndex];
	local endColor = rainbowColors[(_G.colorIndex % totalColors) + 1];
	return {
		lerp(startColor[1], endColor[1], _G.transitionTime);
		lerp(startColor[2], endColor[2], _G.transitionTime);
		lerp(startColor[3], endColor[3], _G.transitionTime);
	};
end

local function getScaleFromDistance(targetPos, localPos)
	if not localPos or not targetPos then
		return 1.0;
	end
	local dx = targetPos.x - localPos.x;
	local dy = targetPos.y - localPos.y;
	local dz = targetPos.z - localPos.z;
	local distance = math.sqrt(dx * dx + dy * dy + dz * dz);
	local baseDistance = 50;
	return math.max(0.3, math.min(2.0, baseDistance / distance));
end

local function getScaleFromScreen(headPos)
	local screenPos = world_to_screen(headPos.x, headPos.y, headPos.z);
	if not screenPos then
		return 1.0;
	end
	local screenWidth = dx9.size().width;
	local screenHeight = dx9.size().height;
	local centerX = screenWidth / 2;
	local centerY = screenHeight / 2;
	local distFromCenter = math.sqrt((screenPos.x - centerX) ^ 2 + (screenPos.y - centerY) ^ 2);
	local maxDist = math.sqrt(centerX ^ 2 + centerY ^ 2);
	return math.max(0.4, math.min(1.5, 1.0 - (distFromCenter / maxDist) * 0.6));
end

local function addVec(v1, v2)
	return { x = v1.x + v2.x, y = v1.y + v2.y, z = v1.z + v2.z };
end

local function scaleVec(v, scale)
	return { x = v.x * scale, y = v.y * scale, z = v.z * scale };
end

local function Draw3DBox(position, cframe, size, color)
	local halfSize = { x = size.x / 2, y = size.y / 2, z = size.z / 2 };
	local corners = {};

	for dx = -1, 1, 2 do
		for dy = -1, 1, 2 do
			for dz = -1, 1, 2 do
				local offset = addVec(
					addVec(
						scaleVec(cframe.RightVector, dx * halfSize.x),
						scaleVec(cframe.UpVector, dy * halfSize.y)
					),
					scaleVec(cframe.LookVector, dz * halfSize.z)
				);
				table.insert(corners, addVec(position, offset));
			end
		end
	end

	local screenPoints = {};
	local allVisible = true;
	for i, world in ipairs(corners) do
		local screenPos = world_to_screen(world.x, world.y, world.z);
		if screenPos then
			screenPoints[i] = { x = screenPos.x, y = screenPos.y };
		else
			allVisible = false;
			break;
		end
	end

	if allVisible then
		local edges = {
			{ 1, 2 }, { 2, 4 }, { 4, 3 }, { 3, 1 };
			{ 5, 6 }, { 6, 8 }, { 8, 7 }, { 7, 5 };
			{ 1, 5 }, { 2, 6 }, { 3, 7 }, { 4, 8 };
		};
		for _, edge in ipairs(edges) do
			local a, b = screenPoints[edge[1]], screenPoints[edge[2]];
			if a and b then
				dx9.DrawLine({ a.x, a.y }, { b.x, b.y }, color);
			end
		end
	end
end

