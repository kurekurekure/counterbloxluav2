local function box2d(x1, y1, x2, y2, c)
	dx9.DrawLine({x1,y1},{x2,y1},c); dx9.DrawLine({x2,y1},{x2,y2},c);
	dx9.DrawLine({x2,y2},{x1,y2},c); dx9.DrawLine({x1,y2},{x1,y1},c);
end

local function hp_bar(x, y, h, hp, maxhp)
	local r = math.max(0, math.min(1, hp / math.max(maxhp, 1)));
	dx9.DrawBox({x-5,y},{x-2,y+h},{40,40,40});
	if r > 0 then dx9.DrawFilledBox({x-4,y+h*(1-r)},{x-3,y+h},{0,255,0}); end
end

local function rainbow()
	local a, b = RAINBOW[S.rainbow_i], RAINBOW[(S.rainbow_i % #RAINBOW) + 1];
	local t = S.rainbow_t;
	return { a[1]+(b[1]-a[1])*t, a[2]+(b[2]-a[2])*t, a[3]+(b[3]-a[3])*t };
end

local function cham_box(p, cf, sz, c)
	local hx, hy, hz = sz[1]/2, sz[2]/2, sz[3]/2;
	local mnX, mnY, mxX, mxY, any;
	for dx = -1, 1, 2 do for dy = -1, 1, 2 do for dz = -1, 1, 2 do
		local ox = cf.RightVector.x*dx*hx + cf.UpVector.x*dy*hy + cf.LookVector.x*dz*hz;
		local oy = cf.RightVector.y*dx*hx + cf.UpVector.y*dy*hy + cf.LookVector.y*dz*hz;
		local oz = cf.RightVector.z*dx*hx + cf.UpVector.z*dy*hy + cf.LookVector.z*dz*hz;
		local s = w2s(p.x+ox, p.y+oy, p.z+oz);
		if s then any = true; mnX = mnX and math.min(mnX,s.x) or s.x; mnY = mnY and math.min(mnY,s.y) or s.y;
			mxX = mxX and math.max(mxX,s.x) or s.x; mxY = mxY and math.max(mxY,s.y) or s.y; end
	end end end
	if any then box2d(mnX, mnY, mxX, mxY, c); end
end

local function run_triggerbot()
	if menu_open() or not on("triggerbot_enabled") or not bind_held("triggerbot_key", TRIG_KEY) or dx9.isLeftClickHeld() then return; end
	local now = os.clock();
	if now - S.trig_last < num("triggerbot_delay", 40) * 0.001 then return; end
	if valid(dx9.GetLocked()) then dx9.Mouse1Click(); S.trig_last = now; return; end
	local cx, cy = scr_center();
	local r2 = num("triggerbot_radius", 14) ^ 2;
	for _, e in ipairs(get_players()) do
		local s = e.head_scr;
		if s then
			local dx, dy = s.x - cx, s.y - cy;
			if dx * dx + dy * dy <= r2 then dx9.Mouse1Click(); S.trig_last = now; return; end
		end
	end
end

local function draw_crosshair()
	if not on("crosshair_enabled") or menu_open() then return; end
	local cx, cy = scr_center();
	local sz, gap, c = num("crosshair_size", 8), num("crosshair_gap", 4), rgb("crosshair");
	local st = str("crosshair_style", "gap cross");
	if st == "dot" then dx9.DrawCircle({cx,cy}, c, math.max(2, math.floor(sz/3)));
	elseif st == "circle" then
		local prev; for i = 0, 16 do local a = i/16*6.283; local pt = {cx+sz*math.cos(a), cy+sz*math.sin(a)};
			if prev then dx9.DrawLine(prev, pt, c); end prev = pt; end
	elseif st == "cross" then
		dx9.DrawLine({cx-sz,cy},{cx+sz,cy},c); dx9.DrawLine({cx,cy-sz},{cx,cy+sz},c);
	else
		dx9.DrawLine({cx-sz,cy},{cx-gap,cy},c); dx9.DrawLine({cx+gap,cy},{cx+sz,cy},c);
		dx9.DrawLine({cx,cy-sz},{cx,cy-gap},c); dx9.DrawLine({cx,cy+gap},{cx,cy+sz},c);
	end
end

