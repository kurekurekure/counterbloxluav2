local BIND_ALIAS = { MB4 = "XBUTTON1", M4 = "XBUTTON1", MOUSE4 = "XBUTTON1", MB5 = "XBUTTON2", M5 = "XBUTTON2", MOUSE5 = "XBUTTON2" };
local BIND_LABEL = { MBUTTON = "M3", RBUTTON = "M2", LBUTTON = "M1", XBUTTON1 = "M4", XBUTTON2 = "M5", MB4 = "M4", MB5 = "M5",
	LCONTROL = "CTRL", RCONTROL = "CTRL", CONTROL = "CTRL", LSHIFT = "SHIFT", RSHIFT = "SHIFT", LMENU = "ALT", RMENU = "ALT" };
local BIND_CODES = {
	CTRL = { "[LCONTROL]", "[RCONTROL]", "[CONTROL]" }, SHIFT = { "[LSHIFT]", "[RSHIFT]", "[SHIFT]" },
	ALT = { "[LMENU]", "[RMENU]", "[MENU]" }, MBUTTON = { "[MBUTTON]" }, RBUTTON = { "[RBUTTON]" }, LBUTTON = { "[LBUTTON]" },
	XBUTTON1 = { "[XBUTTON1]" }, XBUTTON2 = { "[XBUTTON2]" }, MB4 = { "[XBUTTON1]" }, MB5 = { "[XBUTTON2]" },
};

local function norm_bind(s)
	if type(s) ~= "string" or s == "" then return ""; end
	s = s:upper();
	local inner = s:match("^%[(.+)%]$");
	return inner or s;
end

local function resolve_bind(s)
	s = norm_bind(s);
	return s == "" and "" or (BIND_ALIAS[s] or s);
end

local function bind_label(s)
	s = resolve_bind(s);
	return s == "" and "?" or (BIND_LABEL[s] or s);
end

local function bind_name(flag, fb)
	if _G._sr and _G._sr.items then
		for _, it in pairs(_G._sr.items) do
			if it.type == "keybind" and it.flag == flag and it.key and it.key ~= "NONE" then
				return resolve_bind(it.key);
			end
		end
	end
	local v = library.flags[flag];
	if type(v) == "string" and v ~= "" then return resolve_bind(v); end
	return resolve_bind(fb);
end

local function side_down(code)
	if dx9.GetKey() == code then return true; end
	local keys = dx9.GetKeys();
	if type(keys) == "table" then
		for _, k in ipairs(keys) do if k == code then return true; end end
	end
	return false;
end

local function sync_bind(flag, fb)
	local n = bind_name(flag, fb);
	S.keybind_names[flag] = n;
	S.keybind_labels[flag] = bind_label(n);
	return S.keybind_labels[flag];
end

local function bind_held(flag, fb)
	if library.flags[flag] == true then return true; end
	local n = bind_name(flag, fb);
	local codes = BIND_CODES[n];
	if codes then
		for _, c in ipairs(codes) do
			if c == "[XBUTTON1]" or c == "[XBUTTON2]" then
				if side_down(c) then return true; end
			elseif dx9.GetKey() == c then return true; end
		end
	end
	if dx9.GetKey() == "[" .. n .. "]" then return true; end
	if n == "RBUTTON" or n == "M2" then return dx9.isRightClickHeld(); end
	if n == "LBUTTON" or n == "M1" then return dx9.isLeftClickHeld(); end
	if n == "XBUTTON1" or n == "MB4" or n == "M4" or n == "MOUSE4" then return side_down("[XBUTTON1]"); end
	if n == "XBUTTON2" or n == "MB5" or n == "M5" or n == "MOUSE5" then return side_down("[XBUTTON2]"); end
	return false;
end

local function on_bind(flag, v)
	if type(v) == "string" and v ~= "" then
		S.keybind_names[flag] = resolve_bind(v);
		S.keybind_labels[flag] = bind_label(v);
	end
end

local function snap_flags()
	local t = {};
	for k, v in pairs(library.flags) do
		if type(v) == "boolean" or type(v) == "number" or type(v) == "string" then t[k] = v; end
	end
	return t;
end

local function apply_flags(t) for k, v in pairs(t) do library.flags[k] = v; end end

local function add_rgb(sec, p, lbl, def)
