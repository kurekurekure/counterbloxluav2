local function shift_held()
	if dx9.GetKey() == "[LSHIFT]" or dx9.GetKey() == "[RSHIFT]" then return true; end
	local keys = dx9.GetKeys();
	if type(keys) == "table" then
		for _, k in ipairs(keys) do if k == "[LSHIFT]" or k == "[RSHIFT]" then return true; end end
	end
	return false;
end

local function panel_drag(px, py, dk, x, y, w, hh)
	if menu_open() or shift_held() then
		local m = dx9.GetMouse();
		if dx9.isLeftClickHeld() then
			if S[dk] then S[px] = m.x - S[dk].ox; S[py] = m.y - S[dk].oy;
			elseif m.x >= x and m.x <= x + w and m.y >= y and m.y <= y + hh then S[dk] = { ox = m.x - x, oy = m.y - y }; end
		else S[dk] = nil; end
	else S[dk] = nil; end
	return math.floor(S[px]), math.floor(S[py]);
end

local function scr_center()
	local sz = dx9.size();
	return sz.width / 2, sz.height / 2;
end

local function dist3(a, b)
	local dx, dy, dz = a.x - b.x, a.y - b.y, a.z - b.z;
	return math.sqrt(dx * dx + dy * dy + dz * dz);
end

local function planted_bomb()
	if not cache.workspace then return; end
