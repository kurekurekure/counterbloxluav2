local function run_triggerbot()
	if menu_open() then return; end
	if not flag_on("triggerbot_enabled") then return; end
	if not keybind_held("triggerbot_key", config.combat.triggerbot_key or "XBUTTON1") then return; end
	if dx9.isLeftClickHeld() then return; end

	local delay = flag_num("triggerbot_delay", 50) / 1000;
	if S.triggerbot_last and (os.clock() - S.triggerbot_last) < delay then return; end

	local cx, cy = screen_center();
	local radius = flag_num("triggerbot_radius", 14);
	local hit = false;

	for _, entry in ipairs(get_player_entries_cached()) do
		local screen = get_aim_screen(entry);
		if not screen and entry.head_pos then
			screen = world_to_screen_loose(entry.head_pos.x, entry.head_pos.y, entry.head_pos.z);
		end
		if screen then
			local d = math.sqrt((screen.x - cx) ^ 2 + (screen.y - cy) ^ 2);
			if d <= radius then
				hit = true;
				break;
			end
		end
	end

	if not hit then
		local locked = dx9.GetLocked();
		if valid_pointer(locked) then hit = true; end
	end

	if hit then
		dx9.Mouse1Click();
		S.triggerbot_last = os.clock();
	end
end

local function draw_crosshair()
	if not flag_on("crosshair_enabled") or menu_open() then return; end

	local cx, cy = screen_center();
	local size = flag_num("crosshair_size", 8);
	local gap = flag_num("crosshair_gap", 4);
	local col = rgb("crosshair");
	local style = flag_str("crosshair_style", "gap cross");

	if style == "dot" then
		dx9.DrawCircle({ cx, cy }, col, math.max(2, math.floor(size / 3)));
	elseif style == "circle" then
		local prev;
		for seg = 0, 24 do
			local a = (2 * math.pi / 24) * seg;
			local pt = { cx + size * math.cos(a), cy + size * math.sin(a) };
			if prev then dx9.DrawLine(prev, pt, col); end
			prev = pt;
		end
	elseif style == "cross" then
		dx9.DrawLine({ cx - size, cy }, { cx + size, cy }, col);
		dx9.DrawLine({ cx, cy - size }, { cx, cy + size }, col);
	else
		dx9.DrawLine({ cx - size, cy }, { cx - gap, cy }, col);
		dx9.DrawLine({ cx + gap, cy }, { cx + size, cy }, col);
		dx9.DrawLine({ cx, cy - size }, { cx, cy - gap }, col);
		dx9.DrawLine({ cx, cy + gap }, { cx, cy + size }, col);
	end
end

