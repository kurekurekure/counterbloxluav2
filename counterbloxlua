local function scan_items()
	local f = cache.frame;
	if f % 2 ~= 0 or not on("esp_enabled") then return; end
	local items = S.items;
	local scan_w = on("weapons_enabled") or on("grenades_enabled") or on("midair_grenades_enabled");
	local scan_r = on("smoke_radius_enabled") or on("mol_radius_enabled");
	if not scan_w and not scan_r then return; end

	if scan_w then
		items.weapons, items.grenades, items.midair = {}, {}, {};
		if cache.debris then
			for _, item in next, dx9.GetChildren(cache.debris) do
				if valid(dx9.FindFirstChild(item,"Ammo")) and valid(dx9.FindFirstChild(item,"StoredAmmo")) and valid(dx9.FindFirstChild(item,"Mag")) then
					local n = dx9.GetName(item);
					if WEAPONS[n] then
						local mp = pos(dx9.FindFirstChild(item, "Mag"));
						if mp then
							local txt = n;
							if on("weapons_show_ammo") then local a = dx9.GetIntValue(dx9.FindFirstChild(item,"Ammo")); if a then txt = n.." ["..a.."]"; end end
							items.weapons[#items.weapons+1] = { pos = mp, text = txt };
						end
					end
				elseif dx9.GetType(item) == "MeshPart" then
					local n = dx9.GetName(item); local ip = pos(item);
					if ip and NADES[n] then items.grenades[#items.grenades+1] = { pos = ip, label = n };
					elseif ip and n == "Model" then items.midair[#items.midair+1] = { pos = ip }; end
				end
			end
		end
	end

	if scan_r and f % 3 == 0 and cache.ray_ignore then
		items.smokes, items.fires = {}, {};
		local smokes = dx9.FindFirstChild(cache.ray_ignore, "Smokes");
		if smokes then for _, s in next, dx9.GetChildren(smokes) do
			if dx9.GetName(s) == "Smoke" then local p = pos(s); if p then items.smokes[#items.smokes+1] = { pos = p }; end end
		end end
		local fires = dx9.FindFirstChild(cache.ray_ignore, "Fires");
		if fires then for _, fire in next, dx9.GetChildren(fires) do
			if dx9.GetName(fire) == "Fire" then local p = pos(fire); if p then items.fires[#items.fires+1] = { pos = p }; end end
		end end
	end
end

local function draw_item_text(list, col, field)
	for _, e in ipairs(list) do
		local s = w2s(e.pos.x, e.pos.y, e.pos.z);
		if s then local t = e[field]; dx9.DrawString({s.x - dx9.CalcTextWidth(t)/2, s.y}, col, t); end
	end
end

local function draw_items_esp()
	if not on("esp_enabled") then return; end
	if on("weapons_enabled") then draw_item_text(S.items.weapons, rgb("weapons"), "text"); end
	if on("grenades_enabled") then draw_item_text(S.items.grenades, rgb("grenades"), "label"); end
	if on("midair_grenades_enabled") then
		local c = rgb("midair");
		for _, e in ipairs(S.items.midair) do local s = w2s(e.pos.x,e.pos.y,e.pos.z);
			if s then dx9.DrawString({s.x-24,s.y},c,"GRENADE"); dx9.DrawCircle({s.x,s.y},c,6); end
		end
	end
	if on("smoke_radius_enabled") then
		local c = rgb("smoke");
		for _, e in ipairs(S.items.smokes) do
			local p, gy, prev = e.pos, e.pos.y - 0.5;
			for i = 0, 12 do
				local a = i / 12 * 6.283;
				local pt = w2s(p.x + 10.5 * math.cos(a), gy, p.z + 10.5 * math.sin(a));
				if pt and prev then dx9.DrawLine(prev, { pt.x, pt.y }, c); end
				if pt then prev = { pt.x, pt.y }; end
			end
		end
	end
	if on("mol_radius_enabled") then
		local c = rgb("mol");
		for _, e in ipairs(S.items.fires) do
			local p, gy, hs = e.pos, e.pos.y - 0.5, 12;
			local corners = {
				w2s(p.x-hs,gy,p.z-hs), w2s(p.x+hs,gy,p.z-hs), w2s(p.x+hs,gy,p.z+hs), w2s(p.x-hs,gy,p.z+hs),
			};
			if corners[1] and corners[2] and corners[3] and corners[4] then
				for i = 1, 4 do local a, b = corners[i], corners[i%4+1]; dx9.DrawLine({a.x,a.y},{b.x,b.y},c); end
			end
		end
	end
end

