local function sync_aimbot_settings()
	dx9.SetAimbotValue("fov", flag_num("aimbot_fov", 90));
	dx9.SetAimbotValue("smoothness", flag_num("smoothing", 50));
	dx9.SetAimbotValue("range", 5000);
	local mode = flag_str("aimbot_mode", "normal");
	if mode == "silent" then
		dx9.SetAimbotValue("type", 0);
	elseif mode == "legit" then
		dx9.SetAimbotValue("type", 1);
	else
		dx9.SetAimbotValue("type", 1);
	end
end

local function run_aimbot()
	if not flag_on("aimbot_enabled") then return; end
	if not flag_on("aimbot_key") then return; end
	if flag_on("only_rmb") and not dx9.isRightClickHeld() then return; end

	sync_aimbot_settings();

	local cx, cy = dx9.size().width / 2, dx9.size().height / 2;
	local fov_limit = flag_num("aimbot_fov", 90) * 4;
	local best, best_dist;

	for _, entry in ipairs(get_player_entries()) do
		local screen = world_to_screen_loose(entry.head_pos.x, entry.head_pos.y, entry.head_pos.z);
		if screen then
			local d = math.sqrt((screen.x - cx) ^ 2 + (screen.y - cy) ^ 2);
			if d <= fov_limit and (not best_dist or d < best_dist) then
				best = screen;
				best_dist = d;
			end
		end
	end

	if not best then
		local locked = dx9.GetLocked();
		if valid_pointer(locked) then
			local pos = get_position(locked);
			if pos then best = world_to_screen_loose(pos.x, pos.y, pos.z); end
		end
	end

	if best then
		local smooth = math.max(1, flag_num("smoothing", 50));
		local sens = math.max(1, math.floor(100 - smooth * 0.5));
		local mode = flag_str("aimbot_mode", "normal");
		if mode == "silent" then
			dx9.ThirdPersonAim({ best.x, best.y }, smooth, smooth);
		else
			dx9.FirstPersonAim({ best.x, best.y }, smooth, sens);
		end
	end
end

local function run_rcs()
	if not flag_on("rcs_enabled") then
		cache.rcs_y = 0;
		return;
	end
	if not dx9.isLeftClickHeld() then
		cache.rcs_y = 0;
		return;
	end

	local h = flag_num("rcs_h", 80) * 0.015;
	local v = flag_num("rcs_v", 80) * 0.04;
	cache.rcs_y = cache.rcs_y + v;
	local mouse = dx9.GetMouse();
	dx9.MouseMove({ mouse.x + h * 0.1, mouse.y + v });
end

local function run_player_esp()
	if not flag_on("esp_enabled") or not flag_on("player_esp_enabled") then return; end

	local color = rgb("player_esp");
	local draw_boxes = flag_on("player_boxes");
	local draw_hp = flag_on("player_hp");
	local draw_names = flag_on("player_names");

	for _, entry in ipairs(get_player_entries()) do
		local top = world_to_screen_loose(entry.head_pos.x, entry.head_pos.y + 0.5, entry.head_pos.z);
		local bottom = world_to_screen_loose(entry.root_pos.x, entry.root_pos.y - 2.5, entry.root_pos.z);
		if top and bottom then
			local h = math.abs(bottom.y - top.y);
			local w = h * 0.55;
			local x1 = top.x - w / 2;
			local x2 = top.x + w / 2;
			local y1 = top.y;
			local y2 = bottom.y;

			if draw_boxes then draw_box_2d(x1, y1, x2, y2, color); end

			if draw_hp and valid_pointer(entry.humanoid) then
				local hp = dx9.GetHealth(entry.humanoid);
				local max_hp = dx9.GetMaxHealth(entry.humanoid);
				if hp and max_hp then
					draw_health_bar(x1, y1, h, hp, max_hp, { 0, 255, 0 });
				end
			end

			if draw_names and entry.name then
				local label = entry.name;
				dx9.DrawString({ top.x - dx9.CalcTextWidth(label) / 2, y1 - 14 }, color, label);
			end
		end
	end
end

local function run_chinahat()
	if not flag_on("esp_enabled") or not flag_on("chinahat_enabled") then return; end

	for _, entry in ipairs(get_player_entries()) do
		local screen = world_to_screen_loose(entry.head_pos.x, entry.head_pos.y + 0.85, entry.head_pos.z);
		if screen then
			local col = flag_on("chinahat_rainbow") and rainbow_color() or rgb("chinahat");
			local dist = entry.distance > 0 and entry.distance or 50;
			local scale = math.max(0.3, math.min(2, 50 / dist));
			local radius = 28 * scale;
			local height = 18 * scale;
			local top = { screen.x, screen.y - height };
			local seg = 8;

			for i = 0, seg - 1 do
				local a1 = (2 * math.pi / seg) * i;
				local a2 = (2 * math.pi / seg) * (i + 1);
				local p1 = { screen.x + radius * math.cos(a1), screen.y + radius * math.sin(a1) * 0.45 };
				local p2 = { screen.x + radius * math.cos(a2), screen.y + radius * math.sin(a2) * 0.45 };
				dx9.DrawLine(p1, p2, col);
				dx9.DrawLine(p1, top, col);
			end
		end
	end

	if flag_on("chinahat_rainbow") then
		rainbow_fc = rainbow_fc + 1;
		if rainbow_fc % 4 == 0 then
			rainbow_t = rainbow_t + 0.06;
			if rainbow_t >= 1 then rainbow_t = 0; rainbow_i = rainbow_i + 1; if rainbow_i > #rainbowColors then rainbow_i = 1; end end
		end
	end
end

local function run_chams()
	if not flag_on("esp_enabled") or not flag_on("chams_enabled") then return; end
	if cache.frame % 2 ~= 0 then return; end

	for _, entry in ipairs(get_player_entries()) do
		local col = entry.is_teammate and rgb("chams_team") or rgb("chams_enemy");
		for _, part_name in ipairs(CHAM_PARTS) do
			local part = dx9.FindFirstChild(entry.character, part_name);
			if part and partSizes[part_name] then
				local pos = get_position(part);
				local cf = get_cframe(part);
				if pos and cf then draw_cham_box(pos, cf, partSizes[part_name], col); end
			end
		end
	end
end

local function run_bomb_esp()
	if not flag_on("esp_enabled") or not flag_on("bombs_enabled") then return; end
	if not cache.workspace then return; end

	local color = rgb("bombs");
	local debris = cache.debris;
	local dropped = debris and dx9.FindFirstChild(debris, "C4") or nil;
	local planted = dx9.FindFirstChild(cache.workspace, "C4");

	if valid_pointer(dropped) then
		local pos = get_position(dropped);
		local s = pos and world_to_screen_loose(pos.x, pos.y, pos.z);
		if s then dx9.DrawString({ s.x - dx9.CalcTextWidth("C4") / 2, s.y }, color, "C4"); end
	end
	if valid_pointer(planted) then
		local handle = dx9.FindFirstChild(planted, "Handle");
		if valid_pointer(handle) then
			local pos = get_position(handle);
			local s = pos and world_to_screen_loose(pos.x, pos.y, pos.z);
			if s then dx9.DrawString({ s.x - dx9.CalcTextWidth("Planted C4") / 2, s.y }, color, "Planted C4"); end
		end
	end
end

local function run_weapon_esp()
	if not flag_on("esp_enabled") or not flag_on("weapons_enabled") then return; end
	if cache.frame % 2 ~= 0 or not cache.debris then return; end

	local color = rgb("weapons");
	for _, item in next, dx9.GetChildren(cache.debris) do
		if valid_pointer(dx9.FindFirstChild(item, "Ammo"))
			and valid_pointer(dx9.FindFirstChild(item, "StoredAmmo"))
			and valid_pointer(dx9.FindFirstChild(item, "Mag")) then
			local name = dx9.GetName(item);
			if WEAPON_NAMES[name] then
				local mag = dx9.FindFirstChild(item, "Mag");
				local pos = get_position(mag);
				local s = pos and world_to_screen_loose(pos.x, pos.y, pos.z);
				if s then
					local text = name;
					if flag_on("weapons_show_ammo") then
						local ammo = dx9.GetIntValue(dx9.FindFirstChild(item, "Ammo"));
						if ammo then text = name .. " [" .. tostring(ammo) .. "]"; end
					end
					dx9.DrawString({ s.x - dx9.CalcTextWidth(text) / 2, s.y }, color, text);
				end
			end
		end
	end
end

local function run_grenade_esp()
	if not flag_on("esp_enabled") or not flag_on("grenades_enabled") then return; end
	if cache.frame % 2 ~= 0 or not cache.debris then return; end

	local color = rgb("grenades");
	for _, item in next, dx9.GetChildren(cache.debris) do
		if dx9.GetType(item) == "MeshPart" and GRENADE_NAMES[dx9.GetName(item)] then
			local pos = get_position(item);
			local s = pos and world_to_screen_loose(pos.x, pos.y, pos.z);
			if s then
				local n = dx9.GetName(item);
				dx9.DrawString({ s.x - dx9.CalcTextWidth(n) / 2, s.y }, color, n);
			end
		end
	end
end

local function run_midair_esp()
	if not flag_on("esp_enabled") or not flag_on("midair_grenades_enabled") then return; end
	if cache.frame % 2 ~= 0 or not cache.debris then return; end

	local color = rgb("midair");
	for _, item in next, dx9.GetChildren(cache.debris) do
		if dx9.GetType(item) == "MeshPart" and dx9.GetName(item) == "Model" then
			local pos = get_position(item);
			local s = pos and world_to_screen_loose(pos.x, pos.y, pos.z);
			if s then
				dx9.DrawString({ s.x - 24, s.y }, color, "GRENADE");
				dx9.DrawCircle({ s.x, s.y }, color, 6);
			end
		end
	end
end

local function run_smoke_radius()
	if not flag_on("esp_enabled") or not flag_on("smoke_radius_enabled") then return; end
	if cache.frame % 3 ~= 0 or not cache.ray_ignore then return; end

	local smokes = dx9.FindFirstChild(cache.ray_ignore, "Smokes");
	if not smokes then return; end

	local color = rgb("smoke");
	for _, smoke in next, dx9.GetChildren(smokes) do
		if dx9.GetName(smoke) == "Smoke" then
			local pos = get_position(smoke);
			if pos then
				local gy = pos.y - 0.5;
				local prev;
				for i = 0, 16 do
					local a = (2 * math.pi / 16) * i;
					local pt = world_to_screen_loose(pos.x + 10.5 * math.cos(a), gy, pos.z + 10.5 * math.sin(a));
					if pt and prev then dx9.DrawLine(prev, { pt.x, pt.y }, color); end
					prev = pt and { pt.x, pt.y } or prev;
				end
			end
		end
	end
end

local function run_molotov_radius()
	if not flag_on("esp_enabled") or not flag_on("mol_radius_enabled") then return; end
	if cache.frame % 3 ~= 0 or not cache.ray_ignore then return; end

	local fires = dx9.FindFirstChild(cache.ray_ignore, "Fires");
	if not fires then return; end

	local color = rgb("mol");
	for _, fire in next, dx9.GetChildren(fires) do
		if dx9.GetName(fire) == "Fire" then
			local pos = get_position(fire);
			if pos then
				local gy = pos.y - 0.5;
				local hs = 12;
				local corners = {
					world_to_screen_loose(pos.x - hs, gy, pos.z - hs),
					world_to_screen_loose(pos.x + hs, gy, pos.z - hs),
					world_to_screen_loose(pos.x + hs, gy, pos.z + hs),
					world_to_screen_loose(pos.x - hs, gy, pos.z + hs),
				};
				if corners[1] and corners[2] and corners[3] and corners[4] then
					local c = corners;
					dx9.DrawLine({ c[1].x, c[1].y }, { c[2].x, c[2].y }, color);
					dx9.DrawLine({ c[2].x, c[2].y }, { c[3].x, c[3].y }, color);
					dx9.DrawLine({ c[3].x, c[3].y }, { c[4].x, c[4].y }, color);
					dx9.DrawLine({ c[4].x, c[4].y }, { c[1].x, c[1].y }, color);
				end
			end
		end
	end
end

function CB.Run()
	refresh_cache(false);
	apply_fog();
	run_rcs();
	run_aimbot();
	run_player_esp();
	run_chinahat();
	run_chams();
	run_bomb_esp();
	run_weapon_esp();
	run_grenade_esp();
	run_midair_esp();
	run_smoke_radius();
	run_molotov_radius();
	if CB.window and type(CB.window.Render) == "function" then
		CB.window:Render();
	end
end

CB.ready = true;
_G.CounterBlox = CB;
CB.Run();
