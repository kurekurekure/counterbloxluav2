	loadstring(dx9.Get(ui_url))();
end

local function flag_on(name)
	return library.flags[name] == true;
end

local function rgb(prefix)
	return {
		library.flags[prefix .. "_r"] or 0;
		library.flags[prefix .. "_g"] or 0;
		library.flags[prefix .. "_b"] or 0;
	};
end

local function set_rgb_flags(prefix, color)
	library.flags[prefix .. "_r"] = color[1];
	library.flags[prefix .. "_g"] = color[2];
	library.flags[prefix .. "_b"] = color[3];
end

local function add_rgb(section, prefix, label, default)
	set_rgb_flags(prefix, default);
	section:slider({ name = label .. " · R", flag = prefix .. "_r", min = 0, max = 255, default = default[1], interval = 1, suffix = "" });
	section:slider({ name = label .. " · G", flag = prefix .. "_g", min = 0, max = 255, default = default[2], interval = 1, suffix = "" });
	section:slider({ name = label .. " · B", flag = prefix .. "_b", min = 0, max = 255, default = default[3], interval = 1, suffix = "" });
end

local function get_position(instance)
	local pos = dx9.GetPosition(instance);
	if type(pos) == "table" and pos.x ~= nil then
		return pos;
	end
	return nil;
end

local function world_to_screen(x, y, z)
	local screen = dx9.WorldToScreen({ x, y, z });
	if type(screen) ~= "table" then
		return nil;
	end
	if screen.x == nil or screen.y == nil then
		return nil;
	end
	if screen.x < 0 or screen.y < 0 then
		return nil;
	end
	local sw = dx9.size().width;
	local sh = dx9.size().height;
	if screen.x > sw or screen.y > sh then
		return nil;
	end
	return screen;
end

local function get_cframe(part)
	local cf = dx9.GetCFrame(part);
	if type(cf) == "table" and cf.RightVector and cf.LookVector and cf.UpVector then
		return cf;
	end
	local _, right, look, up = dx9.GetCFrame(part);
	if type(right) == "table" and type(look) == "table" and type(up) == "table" then
		return {
			RightVector = right;
			LookVector = look;
			UpVector = up;
		};
	end
	return nil;
end

local function valid_pointer(ptr)
	return ptr ~= nil and ptr ~= 0 and ptr ~= false;
end

