		if not flag_on("esp_enabled") or not flag_on("weapons_enabled") then
			return;
		end

		local datamodel = dx9.GetDatamodel();
		if not datamodel then return; end

		local workspace = dx9.FindFirstChild(datamodel, "Workspace");
		if not workspace then return; end

		local debris = dx9.FindFirstChild(workspace, "Debris");
		if not debris then return; end

		local weapon_color = rgb("weapons");

		for _, item in next, dx9.GetChildren(debris) do
			local ammo = dx9.FindFirstChild(item, "Ammo");
			local stored_ammo = dx9.FindFirstChild(item, "StoredAmmo");
			local mag = dx9.FindFirstChild(item, "Mag");
			if valid_pointer(ammo) and valid_pointer(stored_ammo) and valid_pointer(mag) then
				local weapon_name = dx9.GetName(item);
				if WEAPON_NAMES[weapon_name] then
					local position = get_position(mag);
					if position then
						local screen = world_to_screen(position.x, position.y, position.z);
						if screen then
							local display_text = weapon_name;
							if flag_on("weapons_show_ammo") then
								local current_ammo = dx9.GetIntValue(ammo);
								if current_ammo ~= nil then
