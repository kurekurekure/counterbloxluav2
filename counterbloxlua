local rainbowColors = {
	{ 255, 0, 0 }, { 255, 127, 0 }, { 255, 255, 0 }, { 0, 255, 0 },
	{ 0, 0, 255 }, { 75, 0, 130 }, { 148, 0, 211 },
};

local function lerp(a, b, t) return a + (b - a) * t; end

local function rainbow_color()
	local s = rainbowColors[S.rainbow_i];
	local e = rainbowColors[(S.rainbow_i % #rainbowColors) + 1];
	return { lerp(s[1], e[1], S.rainbow_t), lerp(s[2], e[2], S.rainbow_t), lerp(s[3], e[3], S.rainbow_t) };
end

local function draw_box_2d(x1, y1, x2, y2, color)
	dx9.DrawLine({ x1, y1 }, { x2, y1 }, color);
	dx9.DrawLine({ x2, y1 }, { x2, y2 }, color);
	dx9.DrawLine({ x2, y2 }, { x1, y2 }, color);
	dx9.DrawLine({ x1, y2 }, { x1, y1 }, color);
end

local function draw_health_bar(x, y, h, hp, max_hp, color)
	local ratio = math.max(0, math.min(1, hp / math.max(max_hp, 1)));
	local fill_h = h * ratio;
	dx9.DrawBox({ x - 5, y }, { x - 2, y + h }, { 40, 40, 40 });
	if fill_h > 0 then
		dx9.DrawFilledBox({ x - 4, y + h - fill_h }, { x - 3, y + h }, color);
	end
end

local CHAM_PARTS = { "Head", "UpperTorso", "LowerTorso", "Torso" };
local partSizes = {
	["Head"] = { x = 1.1, y = 1.1, z = 1.1 };
	["Torso"] = { x = 2, y = 2, z = 1 };
	["UpperTorso"] = { x = 2, y = 2, z = 1 };
	["LowerTorso"] = { x = 2, y = 1.5, z = 1 };
};

local function addVec(v1, v2) return { x = v1.x + v2.x, y = v1.y + v2.y, z = v1.z + v2.z }; end
local function scaleVec(v, s) return { x = v.x * s, y = v.y * s, z = v.z * s }; end

local function draw_cham_box(position, cframe, size, color)
	local hs = { x = size.x / 2, y = size.y / 2, z = size.z / 2 };
	local min_x, min_y, max_x, max_y;
	local any = false;
	for dx = -1, 1, 2 do
		for dy = -1, 1, 2 do
			for dz = -1, 1, 2 do
				local offset = addVec(
					addVec(scaleVec(cframe.RightVector, dx * hs.x), scaleVec(cframe.UpVector, dy * hs.y)),
					scaleVec(cframe.LookVector, dz * hs.z)
				);
				local w = addVec(position, offset);
				local s = world_to_screen_loose(w.x, w.y, w.z);
				if s then
					any = true;
					min_x = min_x and math.min(min_x, s.x) or s.x;
					min_y = min_y and math.min(min_y, s.y) or s.y;
					max_x = max_x and math.max(max_x, s.x) or s.x;
					max_y = max_y and math.max(max_y, s.y) or s.y;
				end
			end
		end
	end
	if any and min_x and max_x then
		draw_box_2d(min_x, min_y, max_x, max_y, color);
	end
end

