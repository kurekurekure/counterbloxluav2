	end
	if flag_on("triggerbot_enabled") then
		rows[#rows + 1] = { "TRIGGER", keybind_held("triggerbot_key", config.combat.triggerbot_key or "XBUTTON1"), trig_key };
	end
	if flag_on("rcs_enabled") then
		rows[#rows + 1] = { "RCS", dx9.isLeftClickHeld(), "LMB" };
	end
	if flag_on("esp_enabled") and flag_on("player_esp_enabled") then
		rows[#rows + 1] = { "ESP", true, nil };
	end
	if flag_on("radar_enabled") then
		rows[#rows + 1] = { "RADAR", true, nil };
	end
	if flag_on("bomb_timer") then
		rows[#rows + 1] = { "BOMB TIMER", true, nil };
	end
	rows[#rows + 1] = { "MENU", menu_open(), menu_key };

	local header_h = 18;
	local row_h = 16;
	local pad = 8;
	local w = 150;
	for _, row in ipairs(rows) do
		local text = row[1];
		if row[3] then text = text .. BIND_SEP .. row[3]; end
		w = math.max(w, dx9.CalcTextWidth(text) + 28);
	end
	local h = header_h + pad + (#rows * row_h);

	local sw = dx9.size().width;
	local sh = dx9.size().height;
	if S.kb_hud_x == nil then
		S.kb_hud_x = 12;
		S.kb_hud_y = sh - h - 12;
	end

	local x = math.floor(S.kb_hud_x);
	local y = math.floor(S.kb_hud_y);
	x, y = handle_panel_drag("kb_hud_x", "kb_hud_y", "kb_hud_drag", x, y, w, header_h);

	S.kb_hud_x = math.max(0, math.min(sw - w, S.kb_hud_x));
	S.kb_hud_y = math.max(0, math.min(sh - h, S.kb_hud_y));
	x = math.floor(S.kb_hud_x);
	y = math.floor(S.kb_hud_y);

	dx9.DrawFilledBox({ x, y }, { x + w, y + h }, { 12, 12, 14 });
	dx9.DrawFilledBox({ x, y }, { x + w, y + header_h }, { 18, 18, 22 });
	dx9.DrawFilledBox({ x, y + header_h - 1 }, { x + w, y + header_h }, { 121, 96, 180 });
	dx9.DrawBox({ x, y }, { x + w, y + h }, { 38, 38, 44 });
	dx9.DrawString({ x + 8, y + 4 }, { 200, 200, 210 }, "KEYBINDS");

	for i, row in ipairs(rows) do
		local label, active, bind = row[1], row[2], row[3];
		local line = bind and (label .. BIND_SEP .. bind) or label;
		local ly = y + header_h + 4 + (i - 1) * row_h;
		local dot = active and { 80, 220, 120 } or { 120, 120, 120 };
		dx9.DrawCircle({ x + 10, ly + 5 }, dot, 2);
		dx9.DrawString({ x + 18, ly + 1 }, { 210, 210, 215 }, line);
	end
end

