	local h = hh + pad + #rows * rh;
	local sw, sh = dx9.size().width, dx9.size().height;
	if not S.kb_hud_x then S.kb_hud_x, S.kb_hud_y = 12, sh - h - 12; end
	local x, y = panel_drag("kb_hud_x", "kb_hud_y", "kb_hud_drag", math.floor(S.kb_hud_x), math.floor(S.kb_hud_y), w, hh);
	S.kb_hud_x = math.max(0, math.min(sw - w, S.kb_hud_x)); S.kb_hud_y = math.max(0, math.min(sh - h, S.kb_hud_y));
	x, y = math.floor(S.kb_hud_x), math.floor(S.kb_hud_y);
	dx9.DrawFilledBox({x,y},{x+w,y+h},{12,12,14}); dx9.DrawFilledBox({x,y},{x+w,y+hh},{18,18,22});
	dx9.DrawFilledBox({x,y+hh-1},{x+w,y+hh},{121,96,180}); dx9.DrawBox({x,y},{x+w,y+h},{38,38,44});
	dx9.DrawString({x+8,y+4},{200,200,210},"KEYBINDS");
	for i, r in ipairs(rows) do
		local ly = y + hh + 4 + (i-1)*rh;
		local dot = r[2] and {80,220,120} or {120,120,120};
		local line = r[3] and (r[1]..BIND_SEP..r[3]) or r[1];
		dx9.DrawCircle({x+10, ly+5}, dot, 2); dx9.DrawString({x+18, ly+1},{210,210,215}, line);
	end
end

local function draw_radar()
	if not on("radar_enabled") or not on("esp_enabled") or not cache.local_pos then return; end
	local sw, sh, size, hh = dx9.size().width, dx9.size().height, 118, 18;
	if not S.radar_x then S.radar_x, S.radar_y = sw - size - 14, 34; end
	local rx, ry = panel_drag("radar_x", "radar_y", "radar_drag", math.floor(S.radar_x), math.floor(S.radar_y), size, hh);
	S.radar_x = math.max(0, math.min(sw-size, S.radar_x)); S.radar_y = math.max(0, math.min(sh-size, S.radar_y));
	rx, ry = math.floor(S.radar_x), math.floor(S.radar_y);
	local my, mh = ry + hh, size - hh;
	local cx, cy, scale = rx + size/2, my + mh/2, mh / 130;
	dx9.DrawFilledBox({rx,ry},{rx+size,ry+size},{12,12,14}); dx9.DrawFilledBox({rx,ry},{rx+size,ry+hh},{18,18,22});
	dx9.DrawFilledBox({rx,ry+hh-1},{rx+size,ry+hh},{121,96,180}); dx9.DrawBox({rx,ry},{rx+size,ry+size},{38,38,44});
	dx9.DrawString({rx+8,ry+4},{200,200,210},"RADAR");
	dx9.DrawLine({rx+1,cy},{rx+size-1,cy},{55,55,62}); dx9.DrawLine({cx,my+1},{cx,ry+size-1},{55,55,62});
	local ring = mh/2 - 6;
	for _, e in ipairs(get_players()) do
		local dx = (e.root.x - cache.local_pos.x) * scale;
		local dz = (e.root.z - cache.local_pos.z) * scale;
		local d = math.sqrt(dx*dx + dz*dz);
		if d > ring - 2 and d > 0 then dx, dz = dx/d*(ring-2), dz/d*(ring-2); end
		dx9.DrawCircle({cx+dx, cy+dz}, e.mate and {72,168,255} or {255,72,72}, 3);
	end
	dx9.DrawCircle({cx,cy},{121,96,180},2);
end

local function draw_bomb_timer()
	if not on("bomb_timer") then S.bomb_t0 = nil; return; end
	if not planted_bomb() then S.bomb_t0 = nil; return; end
	S.bomb_t0 = S.bomb_t0 or os.clock();
	local rem = 40 - (os.clock() - S.bomb_t0);
	if rem <= 0 then return; end
	local label = string.format("BOMB  %.2f", rem);
	local col = rem > 10 and {80,220,80} or (rem > 5 and {255,200,0} or {255,60,60});
	local sw, sh = dx9.size().width, dx9.size().height;
	local ww, wh = dx9.CalcTextWidth(label) + 24, 22;
	if not S.bomb_x then S.bomb_x, S.bomb_y = sw/2 - ww/2, 30; end
	local wx, wy = panel_drag("bomb_x", "bomb_y", "bomb_drag", math.floor(S.bomb_x), math.floor(S.bomb_y), ww, wh);
	S.bomb_x = math.max(0, math.min(sw-ww, S.bomb_x)); S.bomb_y = math.max(0, math.min(sh-wh, S.bomb_y));
	wx, wy = math.floor(S.bomb_x), math.floor(S.bomb_y);
	dx9.DrawFilledBox({wx,wy},{wx+ww,wy+wh},{15,15,15}); dx9.DrawBox({wx,wy},{wx+ww,wy+wh},{45,45,45});
	dx9.DrawFilledBox({wx,wy},{wx+ww,wy+2},col); dx9.DrawString({wx+12,wy+5},{230,230,230},label);
	local fill = (ww-4) * (rem/40);
	if fill > 0 then dx9.DrawFilledBox({wx+2,wy+wh-3},{wx+2+fill,wy+wh-1},col); end
end

local function draw_player_esp()
	if not on("esp_enabled") or not on("player_esp_enabled") then return; end
	local c, boxes, hp_on, names = rgb("player_esp"), on("player_boxes"), on("player_hp"), on("player_names");
	for _, e in ipairs(get_players()) do
		local top = w2s(e.head.x, e.head.y + 0.5, e.head.z);
		local bot = w2s(e.root.x, e.root.y - 2.5, e.root.z);
		if top and bot then
			local h = math.abs(bot.y - top.y); local w = h * 0.55;
			local x1, x2, y1, y2 = top.x - w/2, top.x + w/2, top.y, bot.y;
			if boxes then box2d(x1, y1, x2, y2, c); end
			if hp_on and valid(e.humanoid) then
				local hp, mx = dx9.GetHealth(e.humanoid), dx9.GetMaxHealth(e.humanoid);
				if hp and mx then hp_bar(x1, y1, h, hp, mx); end
			end
			if names and e.name then
				local lbl = e.name;
				if on("player_distance") then lbl = lbl .. " [" .. math.floor(e.dist) .. "st]"; end
				dx9.DrawString({top.x - dx9.CalcTextWidth(lbl)/2, y1-14}, c, lbl);
			end
		end
	end
end

local function draw_chinahat()
	if not on("esp_enabled") or not on("chinahat_enabled") then return; end
	for _, e in ipairs(get_players()) do
		local s = w2s(e.head.x, e.head.y + 0.85, e.head.z);
		if s then
			local col = on("chinahat_rainbow") and rainbow() or rgb("chinahat");
			local sc = math.max(0.3, math.min(2, 50 / math.max(e.dist, 1)));
			local r, top = 28*sc, {s.x, s.y - 18*sc};
			for i = 0, 7 do
				local a1, a2 = i/8*6.283, (i+1)/8*6.283;
				local p1 = {s.x+r*math.cos(a1), s.y+r*math.sin(a1)*0.45};
				local p2 = {s.x+r*math.cos(a2), s.y+r*math.sin(a2)*0.45};
				dx9.DrawLine(p1, p2, col); dx9.DrawLine(p1, top, col);
			end
		end
	end
	if on("chinahat_rainbow") then
		S.rainbow_fc = S.rainbow_fc + 1;
		if S.rainbow_fc % 4 == 0 then
			S.rainbow_t = S.rainbow_t + 0.06;
			if S.rainbow_t >= 1 then S.rainbow_t = 0; S.rainbow_i = S.rainbow_i % #RAINBOW + 1; end
		end
	end
end

local function draw_chams()
	if not on("esp_enabled") or not on("chams_enabled") or cache.frame % 2 ~= 0 then return; end
	for _, e in ipairs(get_players()) do
