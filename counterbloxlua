local function addVec(v1, v2) return { x = v1.x + v2.x, y = v1.y + v2.y, z = v1.z + v2.z }; end
local function scaleVec(v, s) return { x = v.x * s, y = v.y * s, z = v.z * s }; end

local function draw_cham_box(position, cframe, size, color)
	local hs = { x = size.x / 2, y = size.y / 2, z = size.z / 2 };
	local min_x, min_y, max_x, max_y;
	local any = false;
	for dx = -1, 1, 2 do
		for dy = -1, 1, 2 do
			for dz = -1, 1, 2 do
				local offset = addVec(
					addVec(scaleVec(cframe.RightVector, dx * hs.x), scaleVec(cframe.UpVector, dy * hs.y)),
					scaleVec(cframe.LookVector, dz * hs.z)
				);
				local w = addVec(position, offset);
				local s = world_to_screen_loose(w.x, w.y, w.z);
				if s then
					any = true;
					min_x = min_x and math.min(min_x, s.x) or s.x;
					min_y = min_y and math.min(min_y, s.y) or s.y;
					max_x = max_x and math.max(max_x, s.x) or s.x;
					max_y = max_y and math.max(max_y, s.y) or s.y;
				end
			end
		end
	end
	if any and min_x and max_x then
		draw_box_2d(min_x, min_y, max_x, max_y, color);
	end
end

local function sync_aimbot_settings()
	dx9.SetAimbotValue("fov", flag_num("aimbot_fov", 90));
	dx9.SetAimbotValue("smoothness", math.max(1, flag_num("smoothing", 15)));
	dx9.SetAimbotValue("sensitivity", math.max(1, flag_num("aimbot_sens", 50)));
	dx9.SetAimbotValue("range", 9999);
	dx9.SetAimbotValue("type", 1);
end

local function aimbot_smooth_sens()
	local mode = flag_str("aimbot_mode", "normal");
	local smooth = math.max(1, math.floor(flag_num("smoothing", 15)));
	local sens = math.max(1, math.floor(flag_num("aimbot_sens", 50)));
	if mode == "silent" then
		return 1, math.max(1, sens);
	elseif mode == "legit" then
		return math.min(100, smooth + 25), math.max(1, math.floor(sens * 0.7));
	end
	return smooth, sens;
end

local function camera_aim_at(x, y)
	local smooth, sens = aimbot_smooth_sens();
	dx9.FirstPersonAim({ math.floor(x), math.floor(y) }, smooth, sens);
end

local function run_aimbot()
	if menu_open() then return; end
	if not flag_on("aimbot_enabled") then return; end
	if not keybind_held("aimbot_key", "MBUTTON") then return; end
	if flag_on("only_rmb") and not dx9.isRightClickHeld() then return; end

	sync_aimbot_settings();

	local cx, cy = screen_center();
	local fov_limit = fov_pixels();
	local best, best_dist;

	for _, entry in ipairs(get_player_entries_cached()) do
		local screen = get_aim_screen(entry);
		if screen then
			local d = math.sqrt((screen.x - cx) ^ 2 + (screen.y - cy) ^ 2);
			if d <= fov_limit and (not best_dist or d < best_dist) then
				best = screen;
				best_dist = d;
			end
		end
	end

	if not best then
		local locked = dx9.GetLocked();
		if valid_pointer(locked) then
			local pos = get_position(locked);
			if pos then
				best = world_to_screen_loose(pos.x, pos.y, pos.z);
			end
		end
	end

	if best then
		camera_aim_at(best.x, best.y);
	end
end

