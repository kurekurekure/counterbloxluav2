local function merge_defaults(dst, src)
	for k, v in pairs(src) do
		if type(v) == "table" then
			dst[k] = dst[k] or {};
			merge_defaults(dst[k], v);
		elseif dst[k] == nil then
			dst[k] = v;
		end
	end
end

