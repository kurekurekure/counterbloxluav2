end

local function pos(inst)
	local p = dx9.GetPosition(inst);
	return type(p) == "table" and p.x and p or nil;
end

local function w2s(x, y, z)
	local s = dx9.WorldToScreen({ x, y, z });
	if type(s) == "table" and s.x and s.y and s.x >= 0 and s.y >= 0 then return s; end
end

local function cframe(part)
	local cf = dx9.GetCFrame(part);
	if type(cf) == "table" and cf.RightVector then return cf; end
	local _, r, l, u = dx9.GetCFrame(part);
	if type(r) == "table" then return { RightVector = r, LookVector = l, UpVector = u }; end
end

local function menu_open()
	if _G._sr and (_G._sr.visible or _G._sr.open) then return true; end
