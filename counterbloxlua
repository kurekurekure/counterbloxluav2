local rainbowColors = {
	{ 255, 0, 0 }, { 255, 127, 0 }, { 255, 255, 0 }, { 0, 255, 0 },
	{ 0, 0, 255 }, { 75, 0, 130 }, { 148, 0, 211 },
};

local function lerp(a, b, t) return a + (b - a) * t; end

local function rainbow_color()
	local s = rainbowColors[S.rainbow_i];
	local e = rainbowColors[(S.rainbow_i % #rainbowColors) + 1];
	return { lerp(s[1], e[1], S.rainbow_t), lerp(s[2], e[2], S.rainbow_t), lerp(s[3], e[3], S.rainbow_t) };
end

local function draw_box_2d(x1, y1, x2, y2, color)
	dx9.DrawLine({ x1, y1 }, { x2, y1 }, color);
	dx9.DrawLine({ x2, y1 }, { x2, y2 }, color);
	dx9.DrawLine({ x2, y2 }, { x1, y2 }, color);
	dx9.DrawLine({ x1, y2 }, { x1, y1 }, color);
end

local function draw_health_bar(x, y, h, hp, max_hp, color)
	local ratio = math.max(0, math.min(1, hp / math.max(max_hp, 1)));
	local fill_h = h * ratio;
	dx9.DrawBox({ x - 5, y }, { x - 2, y + h }, { 40, 40, 40 });
	if fill_h > 0 then
		dx9.DrawFilledBox({ x - 4, y + h - fill_h }, { x - 3, y + h }, color);
	end
end

