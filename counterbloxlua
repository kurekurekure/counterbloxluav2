local function draw_radar()
	if not flag_on("radar_enabled") or not flag_on("esp_enabled") then return; end
	if not cache.local_pos then return; end

	local sw = dx9.size().width;
	local sh = dx9.size().height;
	local size = 118;
	local header = 18;
	local accent = { 121, 96, 180 };
	local bg = { 12, 12, 14 };
	local border = { 38, 38, 44 };

	if S.radar_x == nil then
		S.radar_x = sw - size - 14;
		S.radar_y = 34;
	end

	local rx = math.floor(S.radar_x);
	local ry = math.floor(S.radar_y);
	rx, ry = handle_panel_drag("radar_x", "radar_y", "radar_drag", rx, ry, size, header);

	S.radar_x = math.max(0, math.min(sw - size, S.radar_x));
	S.radar_y = math.max(0, math.min(sh - size, S.radar_y));
	rx = math.floor(S.radar_x);
	ry = math.floor(S.radar_y);
	local map_y = ry + header;
	local map_h = size - header;
	local cx = rx + size / 2;
	local cy = map_y + map_h / 2;
	local scale = map_h / 130;

	dx9.DrawFilledBox({ rx, ry }, { rx + size, ry + size }, bg);
	dx9.DrawFilledBox({ rx, ry }, { rx + size, ry + header }, { 18, 18, 22 });
	dx9.DrawFilledBox({ rx, ry + header - 1 }, { rx + size, ry + header }, accent);
	dx9.DrawBox({ rx, ry }, { rx + size, ry + size }, border);
	dx9.DrawString({ rx + 8, ry + 4 }, { 200, 200, 210 }, "RADAR");

	local grid = { 55, 55, 62 };
	dx9.DrawLine({ rx + 1, cy }, { rx + size - 1, cy }, grid);
	dx9.DrawLine({ cx, map_y + 1 }, { cx, ry + size - 1 }, grid);
	local ring_r = map_h / 2 - 6;
	for i = 1, 2 do
		local r = ring_r * (i / 2);
		local prev;
		for seg = 0, 24 do
			local a = (2 * math.pi / 24) * seg;
			local pt = { cx + r * math.cos(a), cy + r * math.sin(a) };
			if prev then dx9.DrawLine(prev, pt, { 42, 42, 50 }); end
			prev = pt;
		end
	end

	for _, entry in ipairs(get_player_entries_cached()) do
		local dx = (entry.root_pos.x - cache.local_pos.x) * scale;
		local dz = (entry.root_pos.z - cache.local_pos.z) * scale;
		local dist = math.sqrt(dx * dx + dz * dz);
		local max_r = ring_r - 2;
		if dist > max_r and dist > 0 then
			dx = dx / dist * max_r;
			dz = dz / dist * max_r;
		end
		local px = cx + dx;
		local py = cy + dz;
		local dot = entry.is_teammate and { 72, 168, 255 } or { 255, 72, 72 };
		dx9.DrawCircle({ px, py }, dot, 3);
	end

	dx9.DrawCircle({ cx, cy }, accent, 2);
end

local function draw_bomb_timer()
	if not flag_on("bomb_timer") then
		S.bomb_t0 = nil;
		return;
	end

	local planted = get_planted_bomb();
	if not planted then
		S.bomb_t0 = nil;
		return;
	end

	if not S.bomb_t0 then
		S.bomb_t0 = os.clock();
	end

	local remaining = math.max(0, 40 - (os.clock() - S.bomb_t0));
	if remaining <= 0 then return; end

	local label = string.format("BOMB  %.2f", remaining);
	local color;
	if remaining > 10 then
		color = { 80, 220, 80 };
	elseif remaining > 5 then
		color = { 255, 200, 0 };
	else
		color = { 255, 60, 60 };
	end

	local sw = dx9.size().width;
	local sh = dx9.size().height;
	local tw = dx9.CalcTextWidth(label);
	local ww = tw + 24;
	local wh = 22;

	if S.bomb_x == nil then
		S.bomb_x = sw / 2 - ww / 2;
		S.bomb_y = 30;
	end

	local wx = math.floor(S.bomb_x);
	local wy = math.floor(S.bomb_y);
	wx, wy = handle_panel_drag("bomb_x", "bomb_y", "bomb_drag", wx, wy, ww, wh);

	S.bomb_x = math.max(0, math.min(sw - ww, S.bomb_x));
	S.bomb_y = math.max(0, math.min(sh - wh, S.bomb_y));
	wx = math.floor(S.bomb_x);
	wy = math.floor(S.bomb_y);

	dx9.DrawFilledBox({ wx, wy }, { wx + ww, wy + wh }, { 15, 15, 15 });
	dx9.DrawBox({ wx, wy }, { wx + ww, wy + wh }, { 45, 45, 45 });
	dx9.DrawFilledBox({ wx, wy }, { wx + ww, wy + 2 }, color);
	dx9.DrawString({ wx + 12, wy + 5 }, { 230, 230, 230 }, label);

	local bar_w = ww - 4;
	local fill = bar_w * (remaining / 40);
	if fill > 0 then
		dx9.DrawFilledBox({ wx + 2, wy + wh - 3 }, { wx + 2 + fill, wy + wh - 1 }, color);
	end
end

local function run_player_esp()
	if not flag_on("esp_enabled") or not flag_on("player_esp_enabled") then return; end

	local color = rgb("player_esp");
	local draw_boxes = flag_on("player_boxes");
	local draw_hp = flag_on("player_hp");
	local draw_names = flag_on("player_names");

	for _, entry in ipairs(get_player_entries_cached()) do
		local top = world_to_screen_loose(entry.head_pos.x, entry.head_pos.y + 0.5, entry.head_pos.z);
		local bottom = world_to_screen_loose(entry.root_pos.x, entry.root_pos.y - 2.5, entry.root_pos.z);
		if top and bottom then
			local h = math.abs(bottom.y - top.y);
			local w = h * 0.55;
			local x1, x2 = top.x - w / 2, top.x + w / 2;
			local y1, y2 = top.y, bottom.y;

			if draw_boxes then draw_box_2d(x1, y1, x2, y2, color); end

			if draw_hp and valid_pointer(entry.humanoid) then
				local hp = dx9.GetHealth(entry.humanoid);
				local max_hp = dx9.GetMaxHealth(entry.humanoid);
				if hp and max_hp then draw_health_bar(x1, y1, h, hp, max_hp, { 0, 255, 0 }); end
			end

			if draw_names and entry.name then
				local label = entry.name;
				if flag_on("player_distance") and entry.distance then
					label = label .. " [" .. math.floor(entry.distance) .. "st]";
				end
				dx9.DrawString({ top.x - dx9.CalcTextWidth(label) / 2, y1 - 14 }, color, label);
			end
		end
	end
end

local function run_chinahat()
	if not flag_on("esp_enabled") or not flag_on("chinahat_enabled") then return; end

	for _, entry in ipairs(get_player_entries_cached()) do
		local screen = world_to_screen_loose(entry.head_pos.x, entry.head_pos.y + 0.85, entry.head_pos.z);
		if screen then
			local col = flag_on("chinahat_rainbow") and rainbow_color() or rgb("chinahat");
			local dist = entry.distance > 0 and entry.distance or 50;
			local scale = math.max(0.3, math.min(2, 50 / dist));
			local radius = 28 * scale;
			local top = { screen.x, screen.y - 18 * scale };
			local seg = 8;
			for i = 0, seg - 1 do
				local a1 = (2 * math.pi / seg) * i;
				local a2 = (2 * math.pi / seg) * (i + 1);
				local p1 = { screen.x + radius * math.cos(a1), screen.y + radius * math.sin(a1) * 0.45 };
				local p2 = { screen.x + radius * math.cos(a2), screen.y + radius * math.sin(a2) * 0.45 };
				dx9.DrawLine(p1, p2, col);
				dx9.DrawLine(p1, top, col);
			end
		end
	end

	if flag_on("chinahat_rainbow") then
		S.rainbow_fc = S.rainbow_fc + 1;
		if S.rainbow_fc % 4 == 0 then
			S.rainbow_t = S.rainbow_t + 0.06;
			if S.rainbow_t >= 1 then
				S.rainbow_t = 0;
				S.rainbow_i = S.rainbow_i + 1;
				if S.rainbow_i > #rainbowColors then S.rainbow_i = 1; end
			end
		end
	end
end

local function run_chams()
	if not flag_on("esp_enabled") or not flag_on("chams_enabled") then return; end
	if cache.frame % 2 ~= 0 then return; end

	for _, entry in ipairs(get_player_entries_cached()) do
		local col = entry.is_teammate and rgb("chams_team") or rgb("chams_enemy");
		for _, part_name in ipairs(CHAM_PARTS) do
			local part = dx9.FindFirstChild(entry.character, part_name);
			if valid_pointer(part) and partSizes[part_name] then
				local pos = get_position(part);
				local cf = get_cframe(part);
				if pos and cf then draw_cham_box(pos, cf, partSizes[part_name], col); end
			end
		end
	end
end

local function run_bomb_esp()
	if not flag_on("esp_enabled") or not flag_on("bombs_enabled") or not cache.workspace then return; end

	local color = rgb("bombs");
	local dropped = cache.debris and dx9.FindFirstChild(cache.debris, "C4") or nil;
	local planted = dx9.FindFirstChild(cache.workspace, "C4");

	if valid_pointer(dropped) then
		local pos = get_position(dropped);
		local s = pos and world_to_screen_loose(pos.x, pos.y, pos.z);
		if s then dx9.DrawString({ s.x - dx9.CalcTextWidth("C4") / 2, s.y }, color, "C4"); end
	end
	if valid_pointer(planted) then
		local handle = dx9.FindFirstChild(planted, "Handle");
		if valid_pointer(handle) then
			local pos = get_position(handle);
			local s = pos and world_to_screen_loose(pos.x, pos.y, pos.z);
			if s then dx9.DrawString({ s.x - dx9.CalcTextWidth("Planted C4") / 2, s.y }, color, "Planted C4"); end
		end
	end
end

local function scan_world_items()
	if cache.frame % 2 ~= 0 then return; end
	if not flag_on("esp_enabled") then return; end
	if not flag_on("weapons_enabled") and not flag_on("grenades_enabled") and not flag_on("midair_grenades_enabled") then
		return;
	end

	local items = S.items;
	items.weapons = {};
	items.grenades = {};
	items.midair = {};

	if not cache.debris then return; end

	for _, item in next, dx9.GetChildren(cache.debris) do
		if valid_pointer(dx9.FindFirstChild(item, "Ammo"))
			and valid_pointer(dx9.FindFirstChild(item, "StoredAmmo"))
			and valid_pointer(dx9.FindFirstChild(item, "Mag")) then
			local name = dx9.GetName(item);
			if WEAPON_NAMES[name] then
				local mag = dx9.FindFirstChild(item, "Mag");
				local pos = get_position(mag);
				if pos then
					local text = name;
					if flag_on("weapons_show_ammo") then
						local ammo = dx9.GetIntValue(dx9.FindFirstChild(item, "Ammo"));
						if ammo then text = name .. " [" .. tostring(ammo) .. "]"; end
					end
					items.weapons[#items.weapons + 1] = { pos = pos; text = text; };
				end
			end
		elseif dx9.GetType(item) == "MeshPart" then
			local n = dx9.GetName(item);
			if GRENADE_NAMES[n] then
				local pos = get_position(item);
				if pos then
					items.grenades[#items.grenades + 1] = { pos = pos; label = n; };
				end
			elseif n == "Model" then
				local pos = get_position(item);
				if pos then
					items.midair[#items.midair + 1] = { pos = pos; };
				end
			end
		end
	end
end

local function scan_radius_items()
	if cache.frame % 3 ~= 0 then return; end
	if not flag_on("esp_enabled") then return; end
	if not flag_on("smoke_radius_enabled") and not flag_on("mol_radius_enabled") then return; end

	local items = S.items;
	items.smokes = {};
	items.fires = {};

	if not cache.ray_ignore then return; end

	local smokes = dx9.FindFirstChild(cache.ray_ignore, "Smokes");
	if smokes then
		for _, smoke in next, dx9.GetChildren(smokes) do
			if dx9.GetName(smoke) == "Smoke" then
				local pos = get_position(smoke);
				if pos then items.smokes[#items.smokes + 1] = { pos = pos; }; end
			end
		end
	end

	local fires = dx9.FindFirstChild(cache.ray_ignore, "Fires");
	if fires then
		for _, fire in next, dx9.GetChildren(fires) do
			if dx9.GetName(fire) == "Fire" then
				local pos = get_position(fire);
				if pos then items.fires[#items.fires + 1] = { pos = pos; }; end
			end
		end
	end
end

