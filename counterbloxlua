if _G.SmokeRadiusESP == nil then
	_G.SmokeRadiusESP = function()
		if not flag_on("esp_enabled") or not flag_on("smoke_radius_enabled") then
			return;
		end

		local datamodel = dx9.GetDatamodel();
		if not datamodel then return; end

		local workspace = dx9.FindFirstChild(datamodel, "Workspace");
		if not workspace then return; end

		local ray_ignore = dx9.FindFirstChild(workspace, "Ray_Ignore");
		if not ray_ignore then return; end

		local smokes_folder = dx9.FindFirstChild(ray_ignore, "Smokes");
		if not smokes_folder then return; end

		local smoke_color = rgb("smoke");

		for _, smoke in next, dx9.GetChildren(smokes_folder) do
			if dx9.GetName(smoke) == "Smoke" then
				local position = get_position(smoke);
				if position then
					local ground_y = position.y - 0.5;
					local world_radius = 10.5;
					local segments = 36;
					local circle_points = {};

					for i = 0, segments do
						local angle = (2 * math.pi / segments) * i;
						local world_x = position.x + world_radius * math.cos(angle);
						local world_z = position.z + world_radius * math.sin(angle);
						local screen_point = world_to_screen(world_x, ground_y, world_z);
						if screen_point then
							table.insert(circle_points, { screen_point.x, screen_point.y });
						end
					end

					for i = 1, #circle_points do
						local next_i = (i % #circle_points) + 1;
						if circle_points[i] and circle_points[next_i] then
							dx9.DrawLine(circle_points[i], circle_points[next_i], smoke_color);
						end
					end

					local center_screen = world_to_screen(position.x, position.y, position.z);
					if center_screen then
						dx9.DrawString(
							{ center_screen.x - (dx9.CalcTextWidth("SMOKE") / 2), center_screen.y - 20 },
							smoke_color,
							"SMOKE"
						);
					end
				end
			end
		end
	end;
end

if _G.MolotovRadiusESP == nil then
	_G.MolotovRadiusESP = function()
		if not flag_on("esp_enabled") or not flag_on("mol_radius_enabled") then
			return;
		end

		local datamodel = dx9.GetDatamodel();
		if not datamodel then return; end

		local workspace = dx9.FindFirstChild(datamodel, "Workspace");
		if not workspace then return; end

		local ray_ignore = dx9.FindFirstChild(workspace, "Ray_Ignore");
		if not ray_ignore then return; end

		local fires_folder = dx9.FindFirstChild(ray_ignore, "Fires");
		if not fires_folder then return; end

		local molotov_color = rgb("mol");

		for _, fire in next, dx9.GetChildren(fires_folder) do
			if dx9.GetName(fire) == "Fire" then
				local position = get_position(fire);
				if position then
					local ground_y = position.y - 0.5;
					local half_size = 12.0;
					local corners = {
						{ x = position.x - half_size, y = ground_y, z = position.z - half_size };
						{ x = position.x + half_size, y = ground_y, z = position.z - half_size };
						{ x = position.x + half_size, y = ground_y, z = position.z + half_size };
						{ x = position.x - half_size, y = ground_y, z = position.z + half_size };
					};

					local screen_corners = {};
					for i, corner in ipairs(corners) do
						local screen_point = world_to_screen(corner.x, corner.y, corner.z);
						if screen_point then
							screen_corners[i] = { screen_point.x, screen_point.y };
						end
					end

					if #screen_corners == 4 then
						dx9.DrawLine(screen_corners[1], screen_corners[2], molotov_color);
						dx9.DrawLine(screen_corners[2], screen_corners[3], molotov_color);
						dx9.DrawLine(screen_corners[3], screen_corners[4], molotov_color);
						dx9.DrawLine(screen_corners[4], screen_corners[1], molotov_color);
					end

					local center_screen = world_to_screen(position.x, position.y, position.z);
					if center_screen then
						dx9.DrawString(
							{ center_screen.x - (dx9.CalcTextWidth("MOLOTOV") / 2), center_screen.y - 20 },
							molotov_color,
							"MOLOTOV"
						);
					end
				end
			end
		end
	end;
end

