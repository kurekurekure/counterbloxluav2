local function run_smoke_radius()
	if not flag_on("esp_enabled") or not flag_on("smoke_radius_enabled") then return; end
	if cache.frame % 3 ~= 0 or not cache.ray_ignore then return; end

	local smokes = dx9.FindFirstChild(cache.ray_ignore, "Smokes");
	if not smokes then return; end

	local color = rgb("smoke");
	for _, smoke in next, dx9.GetChildren(smokes) do
		if dx9.GetName(smoke) == "Smoke" then
			local pos = get_position(smoke);
			if pos then
				local gy = pos.y - 0.5;
				local prev;
				for i = 0, 16 do
					local a = (2 * math.pi / 16) * i;
					local pt = world_to_screen_loose(pos.x + 10.5 * math.cos(a), gy, pos.z + 10.5 * math.sin(a));
					if pt and prev then dx9.DrawLine(prev, { pt.x, pt.y }, color); end
					if pt then prev = { pt.x, pt.y }; end
				end
			end
		end
	end
end

local function run_molotov_radius()
	if not flag_on("esp_enabled") or not flag_on("mol_radius_enabled") then return; end
	if cache.frame % 3 ~= 0 or not cache.ray_ignore then return; end

	local fires = dx9.FindFirstChild(cache.ray_ignore, "Fires");
	if not fires then return; end

	local color = rgb("mol");
	for _, fire in next, dx9.GetChildren(fires) do
		if dx9.GetName(fire) == "Fire" then
			local pos = get_position(fire);
			if pos then
				local gy = pos.y - 0.5;
				local hs = 12;
				local c = {
					world_to_screen_loose(pos.x - hs, gy, pos.z - hs),
					world_to_screen_loose(pos.x + hs, gy, pos.z - hs),
					world_to_screen_loose(pos.x + hs, gy, pos.z + hs),
					world_to_screen_loose(pos.x - hs, gy, pos.z + hs),
				};
				if c[1] and c[2] and c[3] and c[4] then
					dx9.DrawLine({ c[1].x, c[1].y }, { c[2].x, c[2].y }, color);
					dx9.DrawLine({ c[2].x, c[2].y }, { c[3].x, c[3].y }, color);
					dx9.DrawLine({ c[3].x, c[3].y }, { c[4].x, c[4].y }, color);
					dx9.DrawLine({ c[4].x, c[4].y }, { c[1].x, c[1].y }, color);
				end
			end
		end
	end
end

