end

local function refresh_cache()
	cache.frame = cache.frame + 1;
	local lp = dx9.get_localplayer();
	if lp and lp.Position then cache.local_pos = lp.Position; end
	if cache.frame % 10 ~= 0 and cache.datamodel then return; end

	cache.datamodel = dx9.GetDatamodel();
	if not cache.datamodel then return; end

	local pf = dx9.FindFirstChild(cache.datamodel, "Players");
	cache.workspace = dx9.FindFirstChild(cache.datamodel, "Workspace");
	cache.players = pf and dx9.GetChildren(pf) or {};
	cache.debris = cache.workspace and dx9.FindFirstChild(cache.workspace, "Debris");
	cache.ray_ignore = cache.workspace and dx9.FindFirstChild(cache.workspace, "Ray_Ignore");
	cache.local_team = nil;
	cache.local_player = nil;

	if lp and lp.Position then cache.local_pos = lp.Position; end
	for _, p in next, cache.players do
		local char = dx9.GetCharacter(p);
		local root = char and dx9.FindFirstChild(char, "HumanoidRootPart");
		local rp = root and pos(root);
		if rp and cache.local_pos and dist3(rp, cache.local_pos) < 2 then
			cache.local_team = dx9.GetTeam(p);
			cache.local_player = p;
			break;
		end
	end
end

local function get_players()
	if cache.player_entries_tick == cache.frame then return cache.player_entries or {}; end
	local out, maxd = {}, num("player_max_dist", config.players.player_max_dist or 500);
	for _, p in next, cache.players do
		if p ~= cache.local_player then
			local char = dx9.GetCharacter(p);
			if char then
				local mate = cache.local_team and dx9.GetTeam(p) == cache.local_team;
				if not (on("teamcheck_enabled") and mate) then
					local head = dx9.FindFirstChild(char, "Head");
					local root = dx9.FindFirstChild(char, "HumanoidRootPart") or dx9.FindFirstChild(char, "Torso") or dx9.FindFirstChild(char, "UpperTorso");
					local hp, rp = head and pos(head), root and pos(root);
					if hp and rp and (not cache.local_pos or dist3(rp, cache.local_pos) <= maxd) then
						out[#out + 1] = {
							character = char, humanoid = dx9.FindFirstChild(char, "Humanoid"),
							name = dx9.GetName(p), mate = mate, head = hp, root = rp,
							dist = cache.local_pos and dist3(rp, cache.local_pos) or 0,
							head_scr = w2s(hp.x, hp.y, hp.z),
						};
					end
				end
			end
		end
	end
	cache.player_entries = out;
	cache.player_entries_tick = cache.frame;
	return out;
end

