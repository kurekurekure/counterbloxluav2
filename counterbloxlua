local function resolve_local_player(players_folder, player_instances)
	local local_info = dx9.get_localplayer();
	local local_pos = local_info and local_info.Position or nil;
	local local_team = nil;
	local local_player_instance = nil;

	if local_pos then
		for _, player_instance in next, player_instances do
			local character = dx9.GetCharacter(player_instance);
			if character then
				local root = dx9.FindFirstChild(character, "HumanoidRootPart");
				if root then
					local pos = get_position(root);
					if pos then
						local dist = math.sqrt(
							(pos.x - local_pos.x) ^ 2
								+ (pos.y - local_pos.y) ^ 2
								+ (pos.z - local_pos.z) ^ 2
						);
						if dist < 2 then
							local_team = dx9.GetTeam(player_instance);
							local_player_instance = player_instance;
							break;
						end
					end
				end
			end
		end
	end

	return local_pos, local_team, local_player_instance;
end

if _G.ChamsESP == nil then
	_G.ChamsESP = function()
		if not flag_on("esp_enabled") or not flag_on("chams_enabled") then
			return;
		end

		local datamodel = dx9.GetDatamodel();
		if not datamodel then return; end

		local players_folder = dx9.FindFirstChild(datamodel, "Players");
		if not players_folder then return; end

		local player_instances = dx9.GetChildren(players_folder);
		local _, local_team, local_player_instance = resolve_local_player(players_folder, player_instances);

		for _, player_instance in next, player_instances do
			local should_draw = player_instance ~= local_player_instance;
			local is_teammate = false;

			if should_draw and local_team then
				local player_team = dx9.GetTeam(player_instance);
				if player_team and player_team == local_team then
					is_teammate = true;
					if flag_on("teamcheck_enabled") then
						should_draw = false;
					end
				end
			end

			if should_draw then
				local character = dx9.GetCharacter(player_instance);
				if character then
					local chams_color = is_teammate and rgb("chams_team") or rgb("chams_enemy");
					for _, part in next, dx9.GetChildren(character) do
						local part_type = dx9.GetType(part);
						local part_name = dx9.GetName(part);
						if (part_type == "Part" or part_type == "MeshPart") and partSizes[part_name] then
							local position = get_position(part);
							local cframe = get_cframe(part);
							if position and cframe then
								Draw3DBox(position, cframe, partSizes[part_name], chams_color);
							end
						end
					end
				end
			end
		end
	end;
end

if _G.ChinahatESP == nil then
	_G.ChinahatESP = function()
		if not flag_on("esp_enabled") or not flag_on("chinahat_enabled") then
			return;
		end

		local datamodel = dx9.GetDatamodel();
		if not datamodel then return; end

		local players_folder = dx9.FindFirstChild(datamodel, "Players");
		if not players_folder then return; end

		local player_instances = dx9.GetChildren(players_folder);
		local local_pos, local_team, local_player_instance = resolve_local_player(players_folder, player_instances);

		for _, player_instance in next, player_instances do
			local should_draw = player_instance ~= local_player_instance;

			if should_draw and flag_on("teamcheck_enabled") and local_team then
				local player_team = dx9.GetTeam(player_instance);
				if player_team and player_team == local_team then
					should_draw = false;
				end
			end

			if should_draw then
				local character = dx9.GetCharacter(player_instance);
				if character then
					local head = dx9.FindFirstChild(character, "Head");
					if head then
						local head_position = get_position(head);
						if head_position then
							local screen_position = world_to_screen(
								head_position.x,
								head_position.y + 0.85,
								head_position.z
							);
							if screen_position then
								local current_color = flag_on("chinahat_rainbow")
										and getSmoothRainbowColor()
									or rgb("chinahat");
								local scale = local_pos
										and getScaleFromDistance(head_position, local_pos)
									or getScaleFromScreen(head_position);

								local base_size = 35;
								local cone_height = base_size * 0.7 * scale;
								local radius = base_size * 0.9 * scale;
								local segments = 16;
								local base_circle = {};

								for i = 0, segments do
									local angle = (2 * math.pi / segments) * i;
									local x = screen_position.x + radius * math.cos(angle);
									local y = screen_position.y + radius * math.sin(angle) * 0.5;
									table.insert(base_circle, { x, y });
								end

								local top_point = { screen_position.x, screen_position.y - cone_height };

								for i = 1, #base_circle - 1 do
									dx9.DrawLine(base_circle[i], base_circle[i + 1], current_color);
								end
								dx9.DrawLine(base_circle[#base_circle], base_circle[1], current_color);

								for i = 1, #base_circle do
									dx9.DrawLine(base_circle[i], top_point, current_color);
								end

								for i = 0, 19 do
									local angle = (2 * math.pi / 20) * i;
									local x = screen_position.x + radius * math.cos(angle);
									local y = screen_position.y + radius * math.sin(angle) * 0.5;
									dx9.DrawLine({ x, y }, top_point, current_color);
								end
							end
						end
					end
				end
			end
		end

		if flag_on("chinahat_rainbow") then
			_G.frameCounter = _G.frameCounter + 1;
			if _G.frameCounter % 3 == 0 then
				_G.transitionTime = _G.transitionTime + 0.05;
				if _G.transitionTime >= 1 then
					_G.transitionTime = 0;
					_G.colorIndex = _G.colorIndex + 1;
					if _G.colorIndex > #rainbowColors then
						_G.colorIndex = 1;
					end
				end
			end
		end
	end;
end

if _G.WeaponESP == nil then
